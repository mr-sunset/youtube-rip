global speakerIcon, burnIcon, envPath, audioFormats, videoFormatsset speakerIcon to POSIX file "/System/Library/CoreServices/CoreTypes.bundle/Contents/Resources/GenericSpeaker.icns"set burnIcon to POSIX file "/System/Library/CoreServices/CoreTypes.bundle/Contents/Resources/BurningIcon.icns"set envPath to "export PATH=\"/opt/homebrew/bin:/usr/local/bin:$PATH\"; "set audioFormats to {"mp3", "wav", "flac", "m4a", "aac", "opus"}set videoFormats to {"mp4", "webm", "mov", "3gp"}on extractAudio()	set urlPromptAudio to display dialog "Enter the video URL:" default answer "https://youtu.be/" buttons {"Cancel", "OK"} default button 2 with icon (speakerIcon)		set selectedFormat to choose from list audioFormats with prompt "Select an audio format:" OK button name "Select" default items {"mp3"}	if selectedFormat is false then return	set chosenAudioExt to item 1 of selectedFormat		set givenUrl to text returned of urlPromptAudio		set ripAudio to do shell script envPath & "yt-dlp -x --audio-format " & chosenAudioExt & " -P \"$HOME/Downloads\" --extractor-args \"youtube:player_client=default,-android_sdkless\" " & quoted form of givenUrl		display dialog "Shell stdout: " & ripAudio buttons {"OK"} default button 1 with icon (burnIcon)end extractAudioon extractVideoOnly()	set urlPromptVideo to display dialog "Enter the video URL (Video Only):" default answer "https://youtu.be/" buttons {"Cancel", "OK"} default button 2 with icon (speakerIcon)	set givenUrl to text returned of urlPromptVideo		set selectedFormat to choose from list videoFormats with prompt "Select a video format:" OK button name "Select" default items {"mp4"}	if selectedFormat is false then return	set chosenVideoExt to item 1 of selectedFormat		set ripVideoOnly to do shell script envPath & "yt-dlp -f bestvideo --remux-video " & chosenVideoExt & " -P \"$HOME/Downloads\" --extractor-args \"youtube:player_client=default,-android_sdkless\" " & quoted form of givenUrl		display dialog "Shell stdout: " & ripVideoOnly buttons {"OK"} default button 1 with icon (burnIcon)end extractVideoOnlyon extractVideo()	set urlPromptVideo to display dialog "Enter the video URL:" default answer "https://youtu.be/" buttons {"Cancel", "OK"} default button 2 with icon (speakerIcon)		set givenUrl to text returned of urlPromptVideo		set selectedFormat to choose from list videoFormats with prompt "Select a video format:" OK button name "Select" default items {"mp4"}	if selectedFormat is false then return	set chosenVideoExt to item 1 of selectedFormat		if chosenVideoExt is "mov" then		set formatFlags to "-f \"bestvideo+bestaudio/best\" --remux-video mov"	else if chosenVideoExt is "mp4" then		set formatFlags to "-f \"bv*[ext=mp4]+ba[ext=m4a]/b[ext=mp4]\""	else		set formatFlags to "-f \"bestvideo+bestaudio/best\" --merge-output-format " & chosenVideoExt	end if	set ripVideo to do shell script envPath & "yt-dlp " & formatFlags & " -P \"$HOME/Downloads\" --extractor-args \"youtube:player_client=default,-android_sdkless\" " & quoted form of givenUrl		display dialog "Shell stdout: " & ripVideo buttons {"OK"} default button 1 with icon (burnIcon)end extractVideoset mediaFormats to {"Audio only", "Video only", "Audio and video"}set choice to choose from list mediaFormats with prompt "Choose a media action:" OK button name "Rip" cancel button name "Cancel"if choice is false then	returnelse	set userSelection to item 1 of choice	if userSelection is "Audio only" then		extractAudio()	else if userSelection is "Video only" then		extractVideoOnly()	else if userSelection is "Audio and video" then		extractVideo()	end ifend if