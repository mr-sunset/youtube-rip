-- Gets a YouTube URL and saves an MP3 file of the audio to the Downloads folder.-- NOTE: This may only work on M series Macs, and requires yt-dlp installed via HomeBrew.set speakerIcon to POSIX file "/System/Library/CoreServices/CoreTypes.bundle/Contents/Resources/GenericSpeaker.icns"set burnIcon to POSIX file "/System/Library/CoreServices/CoreTypes.bundle/Contents/Resources/BurningIcon.icns"set envPath to "export PATH=\"/opt/homebrew/bin:/usr/local/bin:$PATH\"; "-- Ask for URLset urlPrompt to display dialog "Enter the video URL:" default answer "https://youtu.be/" with title "YouTube Rip" with icon (speakerIcon)-- Set given URL to variableset givenUrl to text returned of urlPrompt-- Use yt-dlp to rip audio and args to avoid 403set ripAudio to do shell script envPath & "yt-dlp -x --audio-format mp3 -P \"$HOME/Downloads\" --extractor-args \"youtube:player_client=default,-android_sdkless\" " & quoted form of givenUrl-- Display stdoutdisplay dialog "Shell stdout: " & ripAudio with icon (burnIcon)