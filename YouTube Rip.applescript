set envPath to "export PATH=\"/opt/homebrew/bin:/usr/local/bin:$PATH\"; "-- Ask for URLset urlPrompt to display dialog "Enter the video URL:" default answer "https://youtu.be/"-- Set given URL to variableset givenUrl to text returned of urlPrompt-- Use yt-dlp to rip audio and args to avoid 403-- Note: envPath is added to the front, and the path uses $HOME instead of a quoted tildeset ripAudio to do shell script envPath & "yt-dlp -x --audio-format mp3 -P \"$HOME/Downloads\" --extractor-args \"youtube:player_client=default,-android_sdkless\" " & quoted form of givenUrl-- Display stdoutdisplay dialog "Shell: " & ripAudio